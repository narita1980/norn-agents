# Azure OpenAI / AI Foundry
# Foundry なら Portal の OpenAI v1 エンドポイント（…/openai/v1）を推奨。
# 従来リソースなら https://{resource}.openai.azure.com/ も可。
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://aif-norn-dev-east-us2-resource.services.ai.azure.com/openai/v1
AZURE_OPENAI_API_VERSION=2025-04-14
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# GitHub
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# Database (本番: postgresql+asyncpg://user:pass@host/db)
DATABASE_URL=sqlite+aiosqlite:///./norn.db

# App（本番: SWA URL。ローカル: Vite dev server）
NORN_APP_BASE_URL=http://localhost:5173
RUFF_EXECUTABLE=ruff

# Container / Azure (optional)
# PORT=8000
# DATABASE_URL=sqlite+aiosqlite:////data/norn.db
# RUN_MIGRATIONS=1

# Runtime
LOG_LEVEL=INFO
PAYLOAD_SIZE_LIMIT_BYTES=1048576
NORN_ORCHESTRATION_MODE=group_chat
NORN_GROUP_CHAT_MAX_ITERATIONS=7

# NORN_CORS_ORIGINS=https://your-app.azurestaticapps.net
# NORN_BASIC_AUTH_USERNAME=
# NORN_BASIC_AUTH_PASSWORD=
